APP_NAME=OIS API
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ois
AUTO_CREATE_SCHEMA=false
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
AI_MOCK_MODEL=vois-mock-1
AI_API_KEY=
AI_API_BASE=
AI_MOCK_FALLBACK_ENABLED=false
AI_SECRET_BACKEND=environment
AUTH_PROVIDER=firebase
ALLOW_LOCAL_PASSWORD_AUTH=false
SESSION_COOKIE_NAME=ois_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_PATH=/
SESSION_TTL_HOURS=720
ALLOW_LEGACY_HEADER_AUTH=false
ALLOW_BOOTSTRAP_FALLBACK=false
ENABLE_INPROCESS_SCHEDULER=false
AUTH_AUTO_PROVISION_USERS=false
AUTH_DEFAULT_ORGANIZATION_SLUG=
AUTH_DEFAULT_MANAGER_VENUE_SLUG=
AUTH_DEFAULT_BARISTA_VENUE_SLUG=
# Used by explicit launch-account tooling or dev-only seed/import paths, not by normal boot.
SEED_OWNER_EMAIL=owner@vois.local
SEED_MANAGER_EMAIL=manager@vois.local
SEED_BARISTA_EMAIL=barista@vois.local
SEED_DEVELOPER_EMAIL=developer@vois.local
# Optional admin bootstrap for `python -m app.scripts.sync_firebase_launch_accounts`
FIREBASE_OWNER_PASSWORD=
FIREBASE_MANAGER_PASSWORD=
FIREBASE_BARISTA_PASSWORD=
FIREBASE_DEVELOPER_PASSWORD=
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_ADMIN_CREDENTIALS_PATH=
FIREBASE_ADMIN_CREDENTIALS_JSON=
FIREBASE_ROLE_CLAIM_KEY=role
